# ---------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------

UV_RUN := uv run

# ---------------------------------------------------------------------
# Dev Targets
# ---------------------------------------------------------------------

.PHONY: all lint

all: lint

lint:
	$(UV_RUN) ruff check . --fix
	$(UV_RUN) ruff format .
	$(UV_RUN) ty check .

# ---------------------------------------------------------------------
# App Targets
# ---------------------------------------------------------------------

.PHONY: streamlit

# Usage: make streamlit APP={STREAMLIT_SCRIPT.py}
streamlit:
	$(UV_RUN) streamlit run ${APP}
